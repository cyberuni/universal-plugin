{
	"$schema": "https://biomejs.dev/schemas/2.4.16/schema.json",
	"extends": ["@repobuddy/biome/recommended"],
	"files": {
		"includes": ["!!**/bin", "!!**/dist", "!!**/node_modules", "!!.turbo", "!!**/.astro", "!!**/.agents/*.json"]
	},
	"overrides": [
		{
			"includes": ["packages/*/src/**/*.ts", "packages/*/src/**/*.mts"],
			"linter": {
				"rules": {
					"suspicious": {
						"noConsole": {
							"level": "off"
						}
					}
				}
			}
		}
	]
}
