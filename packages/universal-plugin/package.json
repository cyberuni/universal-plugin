{
	"name": "universal-plugin",
	"version": "0.2.0",
	"description": "Universal AI agent plugin build tool",
	"keywords": [
		"agent-plugin",
		"claude-code",
		"cursor",
		"codex",
		"copilot-cli"
	],
	"repository": {
		"type": "git",
		"url": "git+https://github.com/cyberuni/universal-plugin.git",
		"directory": "packages/universal-plugin"
	},
	"license": "MIT",
	"author": "unional <homawong@gmail.com>",
	"type": "module",
	"bin": {
		"universal-plugin": "bin/universal-plugin.mjs"
	},
	"exports": {
		"./package.json": "./package.json"
	},
	"files": [
		"bin",
		"dist",
		"governances"
	],
	"scripts": {
		"build": "tsdown",
		"dev": "tsx src/cli.ts",
		"knip": "knip",
		"lint": "biome check .",
		"prepack": "pnpm build",
		"test": "pnpm build && vitest run src",
		"test:watch": "vitest",
		"typecheck": "tsc --noEmit",
		"verify": "pnpm typecheck && pnpm lint && pnpm test"
	},
	"dependencies": {
		"commander": "^14.0.3"
	},
	"devDependencies": {
		"@types/node": "^24.10.1",
		"knip": "^6.14.1",
		"tsdown": "^0.22.0",
		"tsx": "^4.22.3",
		"typescript": "^6.0.0",
		"vitest": "^4.1.7"
	},
	"packageManager": "pnpm@11.0.0",
	"engines": {
		"node": ">=22"
	},
	"publishConfig": {
		"access": "public",
		"provenance": true
	}
}
